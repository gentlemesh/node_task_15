meta {
  name: getAllProducts
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/products?sortby=price&sort=asc&category=Electronics
  body: none
  auth: none
}

params:query {
  sortby: price
  sort: asc
  category: Electronics
  ~category: stuff
  ~category: Books
}

script:post-response {
  if (res.body.products && res.body.products.length > 0) {
    bru.setVar('firstProductId', res.body.products[0]._id);
    bru.setVar('firstProductName', res.body.products[0].name);
  }
}
