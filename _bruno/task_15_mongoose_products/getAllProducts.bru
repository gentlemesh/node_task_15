meta {
  name: getAllProducts
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/products?category=stuff&sortby=price&sort=asc
  body: none
  auth: none
}

params:query {
  category: stuff
  sortby: price
  sort: asc
}

script:post-response {
  if (res.body.products && res.body.products.length > 0) {
    bru.setVar('firstProductId', res.body.products[0]._id);
    bru.setVar('firstProductName', res.body.products[0].name);
  }
}
